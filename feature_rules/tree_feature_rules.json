{
    "format_version": "1.20.30",
    "minecraft:feature_rules": {
        "description": {
            "identifier": "farlands:tree_feature_rules",
            "places_feature": "farlands:tree/tree_feature_snap"
        },
        "conditions": {
            "placement_pass": "surface_pass",
            "minecraft:biome_filter": {
                "all_of": [
                    {
                        "test": "has_biome_tag",
                        "operator": "not",
                        "value": "nether"
                    },
                    {
                        "test": "has_biome_tag",
                        "operator": "not",
                        "value": "the_end"
                    }
                ]
            }
        },
        "distribution": {
            "iterations": "return  (query.has_biome_tag('bamboo') == 1 ) ? (math.clamp(math.trunc(math.ceil((query.noise(math.trunc(variable.originx / 80), math.trunc(variable.originz / 80)) + 0.3) * 160)), 15, 160)) : ((  (query.has_biome_tag('desert') == 1 || query.has_biome_tag('mesa') == 1)) ? 6 : ( (query.has_biome_tag('cherry_grove') == 1 ) ? 5 : ( (query.has_biome_tag('mangrove_swamp') == 1 ) ? 4 : ( (query.has_biome_tag('taiga') == 1 && query.has_biome_tag('hills') == 1) ? 16 : ( (query.has_biome_tag('forest') == 1 ) ? 16 : ((query.has_biome_tag('ice_plains') == 1 && query.has_biome_tag('mutated') == 1 ) ? 3 : 6) ) ) ) ) );",
            "x": {
                "distribution": "uniform",
                "extent": [
                    0,
                    16
                ]
            },
            "y": {
                "distribution": "uniform",
                "extent": [
                    62,
                    319
                ]
            },
            "z": {
                "distribution": "uniform",
                "extent": [
                    0,
                    16
                ]
            }
        }
    }
}